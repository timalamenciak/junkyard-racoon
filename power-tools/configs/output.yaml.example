# Copy this file to output.yaml and fill in real values.
# output.yaml is gitignored — never commit the real file.
bookstack:
  url: https://your-bookstack-instance
  token_id: your-token-id-here
  token_secret: your-token-secret-here
  pages:
    articles: 1  # page ID for journal articles + collaborator publications
    grants: 2    # page ID for grant opportunities
    tasks: 3     # page ID for project tasks
matrix:
  summary_file: matrix_digest.txt
podcast:
  script_file: podcast_script.md
