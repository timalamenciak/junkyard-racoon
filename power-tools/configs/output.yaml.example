# Copy this file to output.yaml and fill in real values.
# output.yaml is gitignored - never commit the real file.
hedgedoc:
  url: https://your-hedgedoc-instance
  # HedgeDoc 1.x automation relies on a logged-in browser session cookie.
  session_cookie: hedgedoc.sid=replace-me
  # Optional: if alias creation fails but the session is valid, create a random
  # note instead of stopping the pipeline.
  fallback_to_random_new: true
  notes:
    articles: lab-journal-articles
    grants: lab-grant-opportunities
    tasks: lab-project-tasks
    jobs: lab-open-positions
  # The publisher keeps a rolling two-month window locally, publishes a fresh
  # rolling snapshot on each run, and emits archive notes when the window rolls over.
static_site:
  public_url: https://lab.tim-a.ca/digest/
  # Local build output defaults to power-tools/data/output/static_digest_site.
  # Optional deploy target on the server where nginx serves /digest/.
  deploy_dir: /srv/lab-digest
matrix:
  summary_file: matrix_digest.txt
podcast:
  script_file: podcast_script.md
radio:
  # Junkyard Racoon Radio — email-triggered podcast from PDF articles.
  # Send an email from tim.alamenciak@gmail.com with "podcast" in the subject
  # and a PDF attachment. A new numbered episode is generated each night.
  # Requires ANTHROPIC_API_KEY and GEMINI_API_KEY in the environment.
  enabled: true
