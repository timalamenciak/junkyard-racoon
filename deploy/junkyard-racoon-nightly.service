[Unit]
Description=Junkyard Racoon nightly research pipeline
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/junkyard-racoon
ExecStart=/usr/bin/python3 /opt/junkyard-racoon/power-tools/nightly_run.py
StandardOutput=append:/var/log/junkyard-racoon-nightly.log
StandardError=append:/var/log/junkyard-racoon-nightly.log

[Install]
WantedBy=multi-user.target
